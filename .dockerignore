# Git
.git
.gitignore

# Dependencies — installed fresh inside the container
node_modules
**/node_modules

# Build outputs — generated by the builder stage
**/dist
**/.next
**/out

# Solana / Anchor artefacts not needed at runtime
target/
test-ledger/
tests/
programs/
scripts/
attached_assets/
replit.md
daddyx-implementation-summary.md
.replitignore
.agents/
.local/
.config/

# Never bake secrets into the image
.env
.env.*
!.env.example
**/. env
**/.env.local
**/.env.*.local

# Editor & OS
.vscode
.idea
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log
pnpm-debug.log*

# Docker meta (prevent recursive copies)
Dockerfile*
docker-compose*.yml
.dockerignore
